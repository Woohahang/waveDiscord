{
    "compilerOptions": {
        "baseUrl": "./src",
        "paths": {
            "@constants/*": [
                "constants/*"
            ],
            "@events/*": [
                "events/*"
            ],
            "@utils/*": [
                "utils/*"
            ],
            "@services/*": [
                "services/*"
            ],
            "@shared/*": [
                "shared/*"
            ],
            "@errors/*": [
                "errors/*"
            ],
            "@module/*": [
                "module/*"
            ],
            "@modules/*": [
                "modules/*"
            ],
            "@handlers/*": [
                "handlers/*"
            ],
            "@repositories/*": [
                "repositories/*"
            ],
            "@dtos/*": [
                "dtos/*"
            ]
        }
    },
    "include": [
        "src"
    ]
}